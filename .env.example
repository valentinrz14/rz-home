# MercadoPago — obtenelos en https://www.mercadopago.com.ar/developers
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxx

# URL del sitio (sin barra final)
NEXT_PUBLIC_SITE_URL=https://rzroom.com.ar

# Para webhooks de MercadoPago (opcional)
MERCADOPAGO_WEBHOOK_SECRET=tu_secreto_webhook

# Panel de administración — elegí una contraseña segura
ADMIN_PASSWORD=tu_contraseña_segura

# Andreani — para cotización de envío en el checkout
# Obtené tus credenciales en https://developer.andreani.com
# Cambiar a true cuando las credenciales estén listas y probadas
NEXT_PUBLIC_ANDREANI_ENABLED=false
ANDREANI_USUARIO=tu_usuario_andreani
ANDREANI_CLAVE=tu_clave_andreani
ANDREANI_CONTRATO=tu_numero_contrato
ANDREANI_CLIENTE=CL0000000
ANDREANI_QA=false

# Gmail SMTP — para envío de emails transaccionales
# 1. Activar verificación en dos pasos en la cuenta de Google
# 2. Ir a myaccount.google.com → Seguridad → Contraseñas de aplicación
# 3. Crear una contraseña de app (16 caracteres, sin espacios)
GMAIL_USER=ecomerce.rzhome@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxxxxxx
# Email del vendedor para notificaciones de nuevos pedidos (opcional)
EMAIL_NOTIFY=tu@email.com

# Upstash Redis — para órdenes de pago por transferencia/cripto
# Obtené los valores en: upstash.com → tu database → REST API
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp para contacto post-compra (número con código de país, sin +)
WHATSAPP_NUMBER=5491XXXXXXXXXX

# Retiro en local
# PICKUP_ZONA se muestra en el checkout (zona, sin dirección exacta)
# PICKUP_ADDRESS se revela solo después de confirmar el pedido
NEXT_PUBLIC_PICKUP_ZONA="Buenos Aires, Ituzaingó"
PICKUP_ADDRESS="Buenos Aires, Ituzaingó, Cerrito 1696"

# Datos bancarios para transferencia (-10% dto.)
CBU=0000000000000000000000
ALIAS_BANCO=alias.del.banco
TITULAR_BANCO=Nombre Apellido
NRO_CUENTA=123456

# Wallets cripto (−10% descuento)
CRYPTO_WALLET_USDT_TRC20=Txxxxxxxxxxxxxx
CRYPTO_WALLET_USDT_POLYGON=0xxxxxxxxxxx
CRYPTO_WALLET_LTC=Lxxxxxxxxxxxxxxxxxx

# Vercel Cron — auto-generated by Vercel, add manually for local testing
# https://vercel.com/docs/cron-jobs/manage-cron-jobs
CRON_SECRET=tu_cron_secret_generado_por_vercel

# Amazon stock monitoring (URLs de los productos en Amazon)
# La URL de negro simple motor viene por defecto
AMAZON_SIMPLE_NEGRO_URL=https://www.amazon.com/-/es/dp/B0DL589QC3
# La URL de negro doble motor viene por defecto
AMAZON_DOBLE_NEGRO_URL=https://www.amazon.com/-/es/dp/B0DL58KZWN
# URL del doble motor color BLANCO — buscar el ASIN del color blanco en Amazon
# Ejemplo: https://www.amazon.com/-/es/dp/B0DL58KZWN?th=2
AMAZON_DOBLE_BLANCO_URL=
